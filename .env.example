# ─── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── Database (future — swap mock JSON layer for real DB) ─────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cloudeesy_ielts

# ─── Slack Notifications (opt-in) ─────────────────────────────────────────────
# Leave blank to disable — the app works fully without it
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cloudeesy IELTS
